-- Generic Power BI starter measures. Replace table and column names with verified model names.

Row Count =
COUNTROWS ( Fact )

Distinct Entity Count =
DISTINCTCOUNT ( Fact[EntityKey] )

Amount =
SUM ( Fact[Amount] )

Amount YTD =
TOTALYTD ( [Amount], DimDate[Date] )

Amount Previous Year =
CALCULATE ( [Amount], SAMEPERIODLASTYEAR ( DimDate[Date] ) )

Amount Variance =
[Amount] - [Amount Previous Year]

Amount Variance % =
DIVIDE ( [Amount Variance], [Amount Previous Year] )

Rate =
DIVIDE ( [Numerator], [Denominator] )

