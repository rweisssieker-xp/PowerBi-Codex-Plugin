table Dim_Plant
	lineageTag: generated-order2cash-demo

	column PlantID
		dataType: string
		sourceColumn: PlantID

	column CompanyCode
		dataType: string
		sourceColumn: CompanyCode

	column PlantName
		dataType: string
		sourceColumn: PlantName

	column Country
		dataType: string
		sourceColumn: Country

	column IndustryFocus
		dataType: string
		sourceColumn: IndustryFocus

	partition Dim_Plant = m
		mode: import
		source =
			// Power Query M - import Dim_Plant from the industrial demo workbook.
			let
			    Source = Excel.Workbook(File.Contents("C:/tmp/PowerBi-Codex-Plugin/outputs/powerbi-industrial-demo/powerbi_industrial_demo_data.xlsx"), null, true),
			    Raw = Source{[Item="Dim_Plant", Kind="Sheet"]}[Data],
			    PromotedHeaders = Table.PromoteHeaders(Raw, [PromoteAllScalars = true])
			in
			    PromotedHeaders
