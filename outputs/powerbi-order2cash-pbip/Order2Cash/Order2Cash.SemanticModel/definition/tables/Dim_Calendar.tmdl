table Dim_Calendar
	lineageTag: generated-order2cash-demo

	column Date
		dataType: dateTime
		sourceColumn: Date

	column Year
		dataType: int64
		sourceColumn: Year

	column Quarter
		dataType: string
		sourceColumn: Quarter

	column MonthNo
		dataType: int64
		sourceColumn: MonthNo

	column MonthName
		dataType: string
		sourceColumn: MonthName

	column FiscalYear
		dataType: int64
		sourceColumn: FiscalYear

	column FiscalPeriod
		dataType: int64
		sourceColumn: FiscalPeriod

	column IsWorkingDay
		dataType: string
		sourceColumn: IsWorkingDay

	partition Dim_Calendar = m
		mode: import
		source =
			// Power Query M - import Dim_Calendar from the industrial demo workbook.
			let
			    Source = Excel.Workbook(File.Contents("C:/tmp/PowerBi-Codex-Plugin/outputs/powerbi-industrial-demo/powerbi_industrial_demo_data.xlsx"), null, true),
			    Raw = Source{[Item="Dim_Calendar", Kind="Sheet"]}[Data],
			    PromotedHeaders = Table.PromoteHeaders(Raw, [PromoteAllScalars = true])
			in
			    PromotedHeaders
