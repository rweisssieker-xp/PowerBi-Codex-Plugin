table Fact_Order2CashExceptions
	lineageTag: generated-order2cash-demo

	column ExceptionID
		dataType: string
		sourceColumn: ExceptionID

	column ProblemType
		dataType: string
		sourceColumn: ProblemType

	column Severity
		dataType: string
		sourceColumn: Severity

	column CustomerID
		dataType: string
		sourceColumn: CustomerID

	column ProductID
		dataType: string
		sourceColumn: ProductID

	column RelatedDocument
		dataType: string
		sourceColumn: RelatedDocument

	column EventDate
		dataType: dateTime
		sourceColumn: EventDate

	column AmountExposure
		dataType: double
		sourceColumn: AmountExposure

	column Reason
		dataType: string
		sourceColumn: Reason

	column RecommendedAction
		dataType: string
		sourceColumn: RecommendedAction

	column OwnerRole
		dataType: string
		sourceColumn: OwnerRole

	partition Fact_Order2CashExceptions = m
		mode: import
		source =
			// Power Query M - import Fact_Order2CashExceptions exception table.
			let
			    Source = Csv.Document(File.Contents("C:/tmp/PowerBi-Codex-Plugin/outputs/powerbi-order2cash-test/data/Fact_Order2CashExceptions.csv"), [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
			    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars = true])
			in
			    PromotedHeaders
