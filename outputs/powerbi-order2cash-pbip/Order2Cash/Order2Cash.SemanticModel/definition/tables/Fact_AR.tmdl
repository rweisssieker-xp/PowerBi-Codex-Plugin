table Fact_AR
	lineageTag: generated-order2cash-demo

	column InvoiceID
		dataType: string
		sourceColumn: InvoiceID

	column CustomerID
		dataType: string
		sourceColumn: CustomerID

	column DueDate
		dataType: dateTime
		sourceColumn: DueDate

	column OpenAmount
		dataType: double
		sourceColumn: OpenAmount

	column PaymentDate
		dataType: dateTime
		sourceColumn: PaymentDate

	column DisputeFlag
		dataType: boolean
		sourceColumn: DisputeFlag

	column DunningLevel
		dataType: int64
		sourceColumn: DunningLevel

	partition Fact_AR = m
		mode: import
		source =
			// Power Query M - import Fact_AR from the industrial demo workbook.
			let
			    Source = Excel.Workbook(File.Contents("C:/tmp/PowerBi-Codex-Plugin/outputs/powerbi-industrial-demo/powerbi_industrial_demo_data.xlsx"), null, true),
			    Raw = Source{[Item="Fact_AR", Kind="Sheet"]}[Data],
			    PromotedHeaders = Table.PromoteHeaders(Raw, [PromoteAllScalars = true])
			in
			    PromotedHeaders
