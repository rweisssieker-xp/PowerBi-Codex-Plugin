table Dim_Customer
	lineageTag: generated-order2cash-demo

	column CustomerID
		dataType: string
		sourceColumn: CustomerID

	column CustomerName
		dataType: string
		sourceColumn: CustomerName

	column Segment
		dataType: string
		sourceColumn: Segment

	column Industry
		dataType: string
		sourceColumn: Industry

	column Country
		dataType: string
		sourceColumn: Country

	column SalesRegion
		dataType: string
		sourceColumn: SalesRegion

	column RiskClass
		dataType: string
		sourceColumn: RiskClass

	column ActiveFlag
		dataType: boolean
		sourceColumn: ActiveFlag

	partition Dim_Customer = m
		mode: import
		source =
			// Power Query M - import Dim_Customer from the industrial demo workbook.
			let
			    Source = Excel.Workbook(File.Contents("C:/tmp/PowerBi-Codex-Plugin/outputs/powerbi-industrial-demo/powerbi_industrial_demo_data.xlsx"), null, true),
			    Raw = Source{[Item="Dim_Customer", Kind="Sheet"]}[Data],
			    PromotedHeaders = Table.PromoteHeaders(Raw, [PromoteAllScalars = true])
			in
			    PromotedHeaders
