table Fact_Quotes
	lineageTag: generated-order2cash-demo

	column QuoteID
		dataType: string
		sourceColumn: QuoteID

	column OpportunityID
		dataType: string
		sourceColumn: OpportunityID

	column CustomerID
		dataType: string
		sourceColumn: CustomerID

	column QuoteDate
		dataType: dateTime
		sourceColumn: QuoteDate

	column QuoteStatus
		dataType: string
		sourceColumn: QuoteStatus

	column QuoteValue
		dataType: double
		sourceColumn: QuoteValue

	column DiscountPct
		dataType: double
		sourceColumn: DiscountPct

	column ApprovalCycleDays
		dataType: int64
		sourceColumn: ApprovalCycleDays

	column LegalLoopCount
		dataType: int64
		sourceColumn: LegalLoopCount

	partition Fact_Quotes = m
		mode: import
		source =
			// Power Query M - import Fact_Quotes from the industrial demo workbook.
			let
			    Source = Excel.Workbook(File.Contents("C:/tmp/PowerBi-Codex-Plugin/outputs/powerbi-industrial-demo/powerbi_industrial_demo_data.xlsx"), null, true),
			    Raw = Source{[Item="Fact_Quotes", Kind="Sheet"]}[Data],
			    PromotedHeaders = Table.PromoteHeaders(Raw, [PromoteAllScalars = true])
			in
			    PromotedHeaders
