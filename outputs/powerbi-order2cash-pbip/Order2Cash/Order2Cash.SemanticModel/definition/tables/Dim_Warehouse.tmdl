table Dim_Warehouse
	lineageTag: generated-order2cash-demo

	column WarehouseID
		dataType: string
		sourceColumn: WarehouseID

	column PlantID
		dataType: string
		sourceColumn: PlantID

	column WarehouseType
		dataType: string
		sourceColumn: WarehouseType

	column WarehouseName
		dataType: string
		sourceColumn: WarehouseName

	partition Dim_Warehouse = m
		mode: import
		source =
			// Power Query M - import Dim_Warehouse from the industrial demo workbook.
			let
			    Source = Excel.Workbook(File.Contents("C:/tmp/PowerBi-Codex-Plugin/outputs/powerbi-industrial-demo/powerbi_industrial_demo_data.xlsx"), null, true),
			    Raw = Source{[Item="Dim_Warehouse", Kind="Sheet"]}[Data],
			    PromotedHeaders = Table.PromoteHeaders(Raw, [PromoteAllScalars = true])
			in
			    PromotedHeaders
