table Fact_Deliveries
	lineageTag: generated-order2cash-demo

	column DeliveryID
		dataType: string
		sourceColumn: DeliveryID

	column SalesOrderID
		dataType: string
		sourceColumn: SalesOrderID

	column CustomerID
		dataType: string
		sourceColumn: CustomerID

	column ProductID
		dataType: string
		sourceColumn: ProductID

	column WarehouseID
		dataType: string
		sourceColumn: WarehouseID

	column PickDate
		dataType: dateTime
		sourceColumn: PickDate

	column ShipDate
		dataType: dateTime
		sourceColumn: ShipDate

	column DeliveryDate
		dataType: dateTime
		sourceColumn: DeliveryDate

	column DeliveredQty
		dataType: int64
		sourceColumn: DeliveredQty

	column OTIFStatus
		dataType: string
		sourceColumn: OTIFStatus

	column Carrier
		dataType: string
		sourceColumn: Carrier

	partition Fact_Deliveries = m
		mode: import
		source =
			// Power Query M - import Fact_Deliveries from the industrial demo workbook.
			let
			    Source = Excel.Workbook(File.Contents("C:/tmp/PowerBi-Codex-Plugin/outputs/powerbi-industrial-demo/powerbi_industrial_demo_data.xlsx"), null, true),
			    Raw = Source{[Item="Fact_Deliveries", Kind="Sheet"]}[Data],
			    PromotedHeaders = Table.PromoteHeaders(Raw, [PromoteAllScalars = true])
			in
			    PromotedHeaders
