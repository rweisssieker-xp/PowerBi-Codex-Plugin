      "daxMeasureName": "MQL Rate",
      "acceptance": {
        "tolerance": 0.005,
        "reconciliationSource": "CRM funnel report"
      }
    },
    {
      "id": "L2O-003",
      "name": "Order Conversion Rate",
      "grain": "Lead",
      "ownerRole": "Lead2Order Process Owner",
